---
layout: null
permalink: /images/vCards.vcf
---
BEGIN:VCARD
VERSION:4.0
N:{{ site.author.name | split: ' ' | last }};{{ site.author.name | split: ' ' | first }};;;
FN:{{ site.author.name }}
TITLE:{{ site.author.position }}
ORG:;
NOTE:Feel free to contact me with e-mail or SMS!
GENDER:M
PHOTO:{{ site.url }}{{ site.author.avatar | relative_url }}
ADR;TYPE=HOME:;;;{{ site.author.location }};;{{ site.author.country }}
TEL;TYPE=HOME;TYPE=pref;TYPE=VOICE:{{ site.author.phone }}
URL;TYPE=WORK:{{ site.url }}/
EMAIL;TYPE=WORK;TYPE=pref;TYPE=INTERNET:{{ site.author.contact_email | default: site.author.email }}
EMAIL;TYPE=HOME;TYPE=INTERNET:{{ site.author.email }}
END:VCARD
